/**
 * JavaScriptAliveKeeper - JavaScript 保活管理器
 *
 * 用于保持与 JavaScript 的心跳活跃状态，防止系统挂起 JS 执行。
 *
 * **工作原理**：
 * - 该类会周期性地调用提供的心跳回调，以维持 JS 侧的活跃性
 * - 支持引用计数，只有在至少有一个引用时才启动心跳定时器
 * - 心跳定时器仅在有引用时激活，无引用时自动停止
 *
 * **主要场景**：
 * - WebView 失活（比如不在窗口上，系统会尽可能挂起 JS 执行）
 * - Native 侧调用 JS 侧的异步延迟方法，还未处理完，这个时候 JS 挂起，就不会再执行
 * - 通过 `runJavaScript`，可以让 JS 短暂运行，保持执行环境活跃
 *
 * **生命周期管理**：
 * - `increaseReference()` 增加引用计数
 * - `decreaseReference()` 减少引用计数
 * - 当引用计数为 0 时，自动停止心跳定时器
 *
 * - Note: 这是内部类，不应直接使用
 */
export class JavaScriptAliveKeeper {
  /** 心跳定时器的触发间隔（毫秒），用于定时检查是否应该触发心跳 */
  private timerInterval: number;
  /** 心跳回调函数，每次心跳时都会调用 */
  private heartbeat: () => void;
  /** 心跳间隔（毫秒），实际触发心跳的间隔，必须大于 0 */
  private _heartbeatInterval: number = 1000;
  /** 当前引用计数（有多少对象/连接需要保持心跳） */
  private referenceCount: number = 0;
  /** 下次心跳计划的时间点（时间戳，毫秒） */
  private nextHeartbeatTime: number | undefined;
  /** 管理心跳的定时器 */
  private timer: number | undefined;

  /**
   * 以指定心跳时间间隔和回调初始化
   *
   * @param timerInterval 定时器触发的周期（毫秒），用于定时检查是否应该触发心跳
   * @param heartbeat 心跳回调函数
   */
  constructor(timerInterval: number, heartbeat: () => void) {
    this.timerInterval = timerInterval;
    this.heartbeat = heartbeat;
  }

  /**
   * 心跳间隔（毫秒），实际触发心跳的间隔，必须大于 0
   *
   * 修改此值将影响下次心跳的计划时间。若赋值小于等于 0，则保持原值不变。
   */
  get heartbeatInterval(): number {
    return this._heartbeatInterval;
  }

  /**
   * 设置心跳间隔
   * 
   * @param value 新的心跳间隔（毫秒），必须大于 0
   */
  set heartbeatInterval(value: number) {
    if (value <= 0) {
      // 不允许非正数，恢复上一个有效值并打印警告
      console.warn(`Invalid heartbeatInterval, using previous value: ${this._heartbeatInterval}`);
      return;
    }
    const oldValue = this._heartbeatInterval;
    this._heartbeatInterval = value;
    // 更新下次心跳计划时间，保持间隔不变
    if (this.nextHeartbeatTime !== undefined) {
      this.nextHeartbeatTime = this.nextHeartbeatTime + (value - oldValue);
    }
  }

  /**
   * 增加引用计数
   *
   * 当第一个引用到来时自动启动心跳定时器
   */
  increaseReference(): void {
    this.referenceCount += 1;
    if (this.referenceCount === 1) {
      this.startTimer();
    }
  }

  /**
   * 减少引用计数
   *
   * 当引用计数减为 0 时自动停止心跳定时器
   */
  decreaseReference(): void {
    this.referenceCount = Math.max(this.referenceCount - 1, 0);
    if (this.referenceCount === 0) {
      this.stopTimer();
    }
  }

  /**
   * 推迟下次心跳时间
   *
   * 立即把下次心跳推迟到当前时间后的一个心跳间隔
   */
  delay(): void {
    this.nextHeartbeatTime = Date.now() + this.heartbeatInterval;
  }

  /**
   * 启动心跳定时器
   *
   * 若定时器已存在则先停止。定时器每隔 `timerInterval` 检查是否到下次心跳时间。
   * 
   * 工作流程：
   * 1. 停止现有定时器（如果存在）
   * 2. 设置下次心跳时间
   * 3. 创建新的定时器，周期性检查是否需要触发心跳
   */
  private startTimer(): void {
    this.stopTimer();
    this.nextHeartbeatTime = Date.now() + this.heartbeatInterval;
    this.timer = setInterval(() => {
      if (this.nextHeartbeatTime === undefined) {
        return;
      }
      const now = Date.now();
      // 已到计划心跳时间，触发心跳并重新计划下次心跳
      if (now >= this.nextHeartbeatTime) {
        this.heartbeat();
        this.nextHeartbeatTime = now + this.heartbeatInterval;
      }
    }, this.timerInterval);
  }

  /**
   * 停止心跳定时器
   *
   * 释放定时器资源，防止内存泄漏
   */
  private stopTimer(): void {
    if (this.timer !== undefined) {
      clearInterval(this.timer);
      this.timer = undefined;
    }
  }
}

